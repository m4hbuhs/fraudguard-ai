# FraudGuard AI — Environment Variables Example
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/fraud_db

# AI Model Paths
LSTM_MODEL_PATH=models/lstm_model.pth
XGB_MODEL_PATH=models/model.pkl

# Risk Thresholds
XGB_THRESHOLD=0.85
LSTM_THRESHOLD=0.75
XGB_WEIGHT=0.55
LSTM_WEIGHT=0.45

# LLM / RAG
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
